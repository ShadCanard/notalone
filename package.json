{
  "name": "@notalone/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -n Web,Server,PrismaStudio -c cyan,magenta,yellow \"npm run dev:web\" \"npm run dev:server\" \"npm run prisma:studio\"",
    "dev:web": "npm --workspace=apps/web run dev",
    "dev:server": "npm --workspace=apps/server run dev",
    "prisma:studio": "npx prisma studio --browser none",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:push": "npx prisma db push",
    "prisma:seed": "tsx prisma/seed.ts",
    "build": "npm --workspace=apps/web run build && npm --workspace=apps/server run build",
    "lint": "npx eslint \"apps/web/src/**/*.{ts,tsx,js,jsx}\" \"apps/server/src/**/*.{ts,js}\" --ext .ts,.tsx,.js,.jsx"
  },
  "private": true,
  "dependencies": {
    "@mantine/core": "^8.3.18",
    "@mantine/form": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "@mantine/notifications": "^8.3.18",
    "@prisma/client": "^6.9.0",
    "@tabler/icons-react": "^3.40.0",
    "@tanstack/react-query": "^5.91.2",
    "@tanstack/react-query-devtools": "^5.91.3",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "graphql": "^16.13.1",
    "graphql-request": "^7.4.0",
    "graphql-yoga": "^5.18.1",
    "jsonwebtoken": "^9.0.3",
    "next": "^16.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tslib": "^2.8.1",
    "ws": "^8.13.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.18",
    "@swc/helpers": "~0.5.19",
    "graphql-ws": "^5.13.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "multer": "^2.1.1",
    "postcss": "^8.5.8",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "~3.8.1",
    "prisma": "^6.9.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
